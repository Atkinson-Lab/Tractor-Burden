Likelihood = function(param){
alpha = param[1]
sigma = param[2]
tao = param[3]
return(-dmvnorm(y,
mean = (cov * alpha),
sigma = (tao^2 * (G %*% t(G)) + diag(rep(sigma^2 ,6))), log = T))
}
NegLikelihood = function(param){
alpha = param[1]
